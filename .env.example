# MongoDB Atlas connection string (required for production)
MONGODB_URI="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/lukee"

# Server
NODE_ENV="production"
PORT=3000

# Admin JWT signing secret (set a long random value in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: Gemini AI features
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: public app URL (Render or Vercel URL)
APP_URL="https://your-app.vercel.app"

# Razorpay (use test keys in development, live keys in production)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Frontend (Vite) — public key only; must match RAZORPAY_KEY_ID mode
VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"

# Vercel notes:
# - Set MONGODB_URI, JWT_SECRET, RAZORPAY_* in the Vercel project Environment Variables.
# - API runs as a serverless function from /api (see api/index.ts + vercel.json rewrites).
# - Do not rely on a long-running Node process; Mongo connects on cold start.
